{
  "name": "todo-editor",
  "displayName": "todo-editor",
  "publisher": "thomas-benedek-local",
  "description": "todo",
  "repository": {
    "type": "git",
    "url": "https://github.com/t-benedek/vscode-extensions.git",
    "directory": "todo-editor"
  },
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.89.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*",
    "onLanguage:todo",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "todo-editor.helloWorld",
        "title": "Hello World"
      }
    ],
    "languages": [
      {
        "id": "todo",
        "aliases": [
          "ToDo",
          "todo"
        ],
        "extensions": [
          ".todo"
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.89.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
